// 循环左移函数
function rol(x: number, n: number): number {
  return ((x << n) | (x >>> (32 - n))) & 0xFFFFFFFF
}

// MD5哈希函数，返回32位小写十六进制字符串（纯UTS实现）
export function md5(message: string): string {
  // ---------- 辅助函数：将 ASCII 字符串转为字节数组 ----------
  function stringToBytes(str: string): number[] {
      const bytes: number[] = [];
      for (let i = 0; i < str.length; i++) {
          const code: number | null = str.charCodeAt(i);
          if (code != null) {
              bytes.push(code & 0xff); // 取低8位，适用于 ASCII
          }
      }
      return bytes;
  }

  // ---------- MD5 核心实现 (处理字节数组) ----------
  function md5Bytes(bytes: number[]): string {
      // 初始值
      let a0: number = 0x67452301;
      let b0: number = 0xefcdab89;
      let c0: number = 0x98badcfe;
      let d0: number = 0x10325476;

      // 常量表 T (64个)
      const T: number[] = [];
      for (let i = 0; i < 64; i++) {
          T.push(Math.floor(Math.abs(Math.sin(i + 1)) * 0x100000000) >>> 0);
      }

      // 循环左移函数
      function leftRotate(x: number, c: number): number {
          return ((x << c) | (x >>> (32 - c))) >>> 0;
      }

      // ---------- 填充 ----------
      const originalLen = bytes.length;
      const bitLen = originalLen * 8; // 位长度

      // 先添加 0x80
      bytes.push(0x80);

      // 填充 0 直到长度满足 (len + 8) % 64 == 0
      while ((bytes.length + 8) % 64 !== 0) {
          bytes.push(0x00);
      }

      // 添加原始长度 (64位，小端序，先低32位，后高32位)
      bytes.push(bitLen & 0xff);
      bytes.push((bitLen >>> 8) & 0xff);
      bytes.push((bitLen >>> 16) & 0xff);
      bytes.push((bitLen >>> 24) & 0xff);
      const highBits = Math.floor(bitLen / 0x100000000); // 高32位，JavaScript 位运算只能处理32位，用除法
      bytes.push(highBits & 0xff);
      bytes.push((highBits >>> 8) & 0xff);
      bytes.push((highBits >>> 16) & 0xff);
      bytes.push((highBits >>> 24) & 0xff);

      // ---------- 处理每个 64 字节块 ----------
      for (let offset = 0; offset < bytes.length; offset += 64) {
          // 将 64 字节转换为 16 个 32 位字 (小端序)
          const M: number[] = new Array();
          for (let i = 0; i < 16; i++) {
              const base = offset + i * 4;
              M.push((bytes[base]) |
                      (bytes[base + 1] << 8) |
                      (bytes[base + 2] << 16) |
                      (bytes[base + 3] << 24));
          }

          let A: number = a0;
          let B: number = b0;
          let C: number = c0;
          let D: number = d0;

          // 主循环 64 步
          for (let i = 0; i < 64; i++) {
              let F: number, g: number;
              if (i < 16) {
                  F = (B & C) | ((~B) & D);
                  g = i;
              } else if (i < 32) {
                  F = (D & B) | ((~D) & C);
                  g = (5 * i + 1) % 16;
              } else if (i < 48) {
                  F = B ^ C ^ D;
                  g = (3 * i + 5) % 16;
              } else {
                  F = C ^ (B | (~D));
                  g = (7 * i) % 16;
              }

              // 确保 F 是无符号32位
              F = F >>> 0;
              const dTemp: number = D;
              D = C;
              C = B;
              // B = B + leftRotate((A + F + M[g] + T[i]), s[i])  其中 s[i] 是位移量
              const s: number[] = [
                  7, 12, 17, 22, 7, 12, 17, 22, 7, 12, 17, 22, 7, 12, 17, 22,
                  5, 9, 14, 20, 5, 9, 14, 20, 5, 9, 14, 20, 5, 9, 14, 20,
                  4, 11, 16, 23, 4, 11, 16, 23, 4, 11, 16, 23, 4, 11, 16, 23,
                  6, 10, 15, 21, 6, 10, 15, 21, 6, 10, 15, 21, 6, 10, 15, 21
              ];
              const sum = (A + F + M[g] + T[i]) >>> 0;
              const rotated = leftRotate(sum, s[i]);
              B = (B + rotated) >>> 0;
              A = dTemp;
          }

          // 更新初始值
          a0 = (a0 + A) >>> 0;
          b0 = (b0 + B) >>> 0;
          c0 = (c0 + C) >>> 0;
          d0 = (d0 + D) >>> 0;
      }

      // ---------- 输出十六进制 (小端序：每个寄存器的低字节在前) ----------
      function wordToLittleEndianBytes(word: number): number[] {
          return [
              word & 0xff,
              (word >>> 8) & 0xff,
              (word >>> 16) & 0xff,
              (word >>> 24) & 0xff
          ];
      }

      const resultBytes: number[] = [];
      resultBytes.push(...wordToLittleEndianBytes(a0));
      resultBytes.push(...wordToLittleEndianBytes(b0));
      resultBytes.push(...wordToLittleEndianBytes(c0));
      resultBytes.push(...wordToLittleEndianBytes(d0));

      // 将字节数组转为十六进制字符串
      let hex = '';
      for (let i = 0; i < resultBytes.length; i++) {
          const byte = resultBytes[i];
          hex += ((byte >>> 4) & 0x0f).toString(16);
          hex += (byte & 0x0f).toString(16);
      }
      return hex;
  }

  // 将输入字符串转为字节数组并计算 MD5
  return md5Bytes(stringToBytes(message));
}

// 双重加密带时间戳：先加密密码，拼接时间戳，再加密整个字符串
export function doubleEncryptWithTimestamp(password: string, keyB64: string): string {
  console.error('[doubleEncryptWithTimestamp] 开始双重加密')
  console.error('[doubleEncryptWithTimestamp] 原始密码:', password)
  console.error('[doubleEncryptWithTimestamp] 密钥Base64:', keyB64)
  
  // 先对密码进行MD5哈希（32位小写）
  const md5Password = md5(password)
  console.error('[doubleEncryptWithTimestamp] MD5后密码:', md5Password)
  
  // 获取当前时间戳（毫秒）
  const timestamp = Date.now().toString()
  console.error('[doubleEncryptWithTimestamp] 时间戳:', timestamp)
  
  // 第一步：使用新加密方法加密MD5后的密码
  console.error('[doubleEncryptWithTimestamp] 第一步加密开始')
  const firstEncrypted = encryptAesEcbPkcs7Base64ToHex(md5Password, keyB64)
  console.error('[doubleEncryptWithTimestamp] 第一步加密结果:', firstEncrypted)
  
  // 拼接：加密结果 + 逗号 + 时间戳
  const combined = `${firstEncrypted},${timestamp}`
  console.error('[doubleEncryptWithTimestamp] 拼接后的字符串:', combined)
  
  // 第二步：再次使用新加密方法加密拼接后的字符串
  console.error('[doubleEncryptWithTimestamp] 第二步加密开始')
  const finalEncrypted = encryptAesEcbPkcs7Base64ToHex(combined, keyB64)
  console.error('[doubleEncryptWithTimestamp] 最终加密结果:', finalEncrypted)
  
  return finalEncrypted
}
