      </view>
      
      <!-- 右侧功能菜单 -->
      <view class="nav-right-buttons">
        <!-- 数据看板入口 -->
        <view class="nav-dashboard-btn" @click="navigateToStatistics">
          <image class="dashboard-icon" src="/static/icons/dashboard.svg" mode="widthFix"></image>
          <text class="dashboard-text">数据看板</text>
        </view>
        
        <!-- 消息入口按钮 -->
        <view class="nav-message-btn">
          <text class="message-text">消息</text>
          <view class="message-badge">4</view>
        </view>
      </view>
    </view>

    <view class="index-logo-container">
      <image class="index-logo" src="/static/index-logo.png" mode="aspectFit"></image>
    </view>

    <!-- 功能网格 -->
    <view class="func-grid">
      <!-- 第一行 -->
      <view class="func-row">
        <view class="func-item" @click="onFuncClick('支部党员大会')">
          <image class="func-icon" src="/static/icons/party_meeting.svg" mode="widthFix"></image>
          <text class="func-text">支部党员大会</text>
        </view>
        <view class="func-item" @click="onFuncClick('支部委员会')">
          <image class="func-icon" src="/static/icons/branch_committee.svg" mode="widthFix"></image>
          <text class="func-text">支部委员会</text>
        </view>
      </view>
      
      <!-- 第二行 -->
      <view class="func-row">
        <view class="func-item" @click="onFuncClick('党小组会')">
          <image class="func-icon" src="/static/icons/party_cell.svg" mode="widthFix"></image>
          <text class="func-text">党小组会</text>
        </view>
        <view class="func-item" @click="onFuncClick('党课')">
          <image class="func-icon" src="/static/icons/party_lecture.svg" mode="widthFix"></image>
          <text class="func-text">党课</text>
        </view>
      </view>
      
      <!-- 第三行 -->
      <view class="func-row">
        <view class="func-item" @click="onFuncClick('理论学习')">
          <image class="func-icon" src="/static/icons/theory_study.svg" mode="widthFix"></image>
          <text class="func-text">理论学习</text>
