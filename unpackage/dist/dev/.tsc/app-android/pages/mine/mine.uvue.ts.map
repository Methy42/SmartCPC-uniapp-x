    <image class="background-image" src="/static/background/u2.jpg" mode="aspectFill"></image>

    <!-- 顶部通栏 - 自定义导航栏 -->
    <view class="custom-navbar">
      <!-- 左侧头像 -->
      <view class="nav-avatar-container">
        <image class="nav-avatar" src="/static/login-avatar.png" mode="aspectFill"></image>
      </view>

      <view class="nav-logo-container">
        <image class="nav-logo" src="/static/index-logo.png" mode="aspectFit"></image>
      </view>
      
      <!-- 右侧功能菜单 -->
      <view class="nav-right-buttons">
        
        <!-- 消息入口按钮 -->
        <view class="nav-message-btn">
          <text class="message-text">消息</text>
          <view class="message-badge">4</view>
        </view>
      </view>
    </view>

    <view class="content-container">
      <view class="content-title-container">
        <image class="content-title-background" src="/static/mine-title-background.png" mode="aspectFit"></image>
        <text class="content-title-text">个人中心</text>
      </view>

      <view class="profile-card">
        <view class="avatar-circle">
          <image class="profile-avatar" src="/static/avatar.png" mode="aspectFill"></image>
        </view>
        <view class="profile-info">
          <view class="name-id-row">
            <text class="name">李绍丽</text>
            <view class="id-chip"><text class="id">党员</text></view>
          </view>
          <text class="branch-text">所在党组织：数智公司党支部</text>
        </view>
      </view>

      <view class="menu-card">
        <view class="menu-item" @tap="goPersonalInfo">
