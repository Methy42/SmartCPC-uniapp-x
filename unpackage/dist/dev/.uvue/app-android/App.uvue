        // 修复类型推断：显式转换为布尔值
        const isFirstBack = firstBackTime === 0;
        if (isFirstBack) {
            uni.showToast({
                title: '再按一次退出应用',
                position: 'bottom',
            });
            firstBackTime = Date.now();
            setTimeout(() => {
                firstBackTime = 0;
            }, 2000);
        }
        else {
            const timeDiff = Date.now() - firstBackTime;
            const isWithinTwoSeconds = timeDiff < 2000;
            if (isWithinTwoSeconds) {
                firstBackTime = Date.now();
                uni.exit();
            }
        }
