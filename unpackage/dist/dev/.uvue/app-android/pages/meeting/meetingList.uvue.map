<script setup lang="ts">
import { ref } from 'vue'

// 选项卡数据
const tabList = ref([
  { name: '待开会议' },
  { name: '已开会议' }
])
const activeTab = ref(0)

const showJoinModal = ref(false)
const attendType = ref<'onsite' | 'video'>('onsite')
const joined = ref(false)
function openJoinModal() {
  showJoinModal.value = true
}
function closeJoinModal() {
  showJoinModal.value = false
}
function confirmJoin() {
  showJoinModal.value = false
  joined.value = true
  uni.showToast({ title: '已报名参加', icon: 'success' })
}

const showLeaveModal = ref(false)
const leaveReason = ref('')
function openLeaveModal() {
  showLeaveModal.value = true
}
function closeLeaveModal() {
  showLeaveModal.value = false
}
function submitLeave() {
  showLeaveModal.value = false
  uni.showToast({ title: '已提交请假', icon: 'success' })
}

function onLeaveInput(e: UniInputEvent) {
  leaveReason.value = e.detail.value
}

const showSignatureModal = ref(false)
let signatureCanvasEl: UniCanvasElement | null = null
let signature2d: CanvasRenderingContext2D | null = null
function openSignatureModal() {
  showSignatureModal.value = true
  try {
    const pages = getCurrentPages()
    const currentPage = pages[pages.length - 1]
    currentPage.setPageStyle({ pageOrientation: 'landscape' } as UTSJSONObject)
  } catch (_) {}
  setTimeout(() => {
    signatureCanvasEl = uni.getElementById('signature-canvas') as UniCanvasElement
    if (signatureCanvasEl !== null) {
      signature2d = signatureCanvasEl.getContext('2d')!
      const dpr = uni.getWindowInfo().pixelRatio
      const rect = signatureCanvasEl.getBoundingClientRect()
      signatureCanvasEl.width = rect.width * dpr
      signatureCanvasEl.height = rect.height * dpr
      signature2d!.scale(dpr, dpr)
      signature2d!.lineWidth = 3
      signature2d!.strokeStyle = '#333'
    }
  }, 50)
}
function closeSignatureModal() {
  showSignatureModal.value = false
  try {
    const pages = getCurrentPages()
    const currentPage = pages[pages.length - 1]
    currentPage.setPageStyle({ pageOrientation: 'portrait' } as UTSJSONObject)
  } catch (_) {}
}
let drawing = false
function sigStart(e: UniTouchEvent) {
  if (signature2d === null || signatureCanvasEl === null) { return }
  drawing = true
  const t = e.touches[0]
  const rect = signatureCanvasEl.getBoundingClientRect()
  const x = t.clientX - rect.left
  const y = t.clientY - rect.top
  signature2d!.beginPath()
  signature2d!.moveTo(x, y)
}
function sigMove(e: UniTouchEvent) {
  if (signature2d === null || signatureCanvasEl === null || drawing === false) { return }
  const t = e.touches[0]
  const rect = signatureCanvasEl.getBoundingClientRect()
  const x = t.clientX - rect.left
  const y = t.clientY - rect.top
  signature2d!.lineTo(x, y)
  signature2d!.stroke()
}
function sigEnd() {
  drawing = false
}
function sigClear() {
  if (signature2d === null || signatureCanvasEl === null) { return }
  signature2d!.clearRect(0, 0, signatureCanvasEl.width, signatureCanvasEl.height)
}
</script>

