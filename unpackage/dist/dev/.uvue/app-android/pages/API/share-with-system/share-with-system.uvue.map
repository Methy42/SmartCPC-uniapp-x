						})
					},
					complete(_) {

					}
				})
			},
			sharePubImg() {
				uni.hideToast()
				uni.chooseImage({
					count: 3,
					sourceType: ['camera', 'album'],
					success(e) {
						console.log(e)
						console.log(JSON.stringify(e))
						uni.shareWithSystem({
							// summary: "aa",
							// href: 'https://uniapp.dcloud.io',
							imagePaths: e.tempFilePaths,
							type:'image',
							success(_) {
								console.log('Shared----------------------------success')
								// 分享完成，请注意此时不一定是成功分享
							},
